/**
 * @file smart_home.ino
 * @brief Ultra-Fast Presentation-Optimized BioPulse Firmware
 * @note Tuned explicitly for instant state-switching during a 2-minute live demo.
 */

#include <LiquidCrystal.h>

// --- HARDWARE INTERFACE PIN ASSIGNMENTS ---
const int PIN_LCD_RS     = 12;
const int PIN_LCD_E      = 11;
const int PIN_LCD_D4     = 5;
const int PIN_LCD_D5     = 4;
const int PIN_LCD_D6     = 3;
const int PIN_LCD_D7     = 2;

const int PIN_SENS_TEMP  = A0;
const int PIN_SENS_GAS   = A1;
const int PIN_SENS_LDR   = A2;
const int PIN_SENS_PIR   = 7;

const int PIN_ACT_SERVO  = 9;
const int PIN_ACT_RELAY  = 8;
const int PIN_ACT_BUZZER = 6;

const int PIN_LED_GREEN  = 10; // State: Deep System Sleep Emulation
const int PIN_LED_YELLOW = 13; // State: Neuromorphic Spike Detected
const int PIN_LED_RED    = A3; // State: Critical Hazard Overdrive

// --- LIQUID CRYSTAL DRIVER OBJECT ---
LiquidCrystal lcd(PIN_LCD_RS, PIN_LCD_E, PIN_LCD_D4, PIN_LCD_D5, PIN_LCD_D6, PIN_LCD_D7);

// --- ACCELERATED NEUROMORPHIC PARAMETERS ---
const float LEAK_RATE          = 0.80;  // Aggressive leak rate for fast recovery
const float SPIKE_THRESHOLD    = 5.0;   // Highly sensitive local trigger barrier
const float GLOBAL_ACTIVATION  = 15.0;  // Rapid network ignition limit

// --- MEMBRANE ACCUMULATOR STORAGE ---
float membranePotentialTemp = 0.0;
float membranePotentialGas  = 0.0;
float membranePotentialLDR  = 0.0;

// --- SENSOR TRACKING ARRAYS (PREVIOUS STATES) ---
int prevRawTemp = 500;
int prevRawGas  = 200;
int prevRawLDR  = 500;

// --- HOMEOSTATIC SELF-LEARNING ENGINE ---
float adaptiveBaselineTemp = 25.0;  
float adaptiveBaselineGas  = 150.0; 

// --- CRITICAL PRESENTATION TIMING REGISTERS ---
unsigned long previousSamplingTime = 0;
unsigned long previousWakeHoldTime  = 0;
const unsigned long SAMPLING_INTERVAL = 50;     // Sample rapidly every 50ms
const unsigned long WAKE_HOLD_DURATION = 750;   // Snappy recovery: drop to sleep in 750ms flat

// --- SYSTEM STATE FLAGS ---
bool isSystemAwake = false;
bool forceLcdUpdate = true;

// --- HELPER FUNCTION FOR VOLTAGE CONVERSION ---
float calculateVoltage(int analogADCReading) {
    return (analogADCReading * 5.0) / 1023.0;
}

// --- STREAMLINED SERVO CONTROLLER ---
void positionMicroServo(int angularDegrees) {
    int highPulseDuration = map(angularDegrees, 0, 180, 500, 2400);
    for(int dutyCycles = 0; dutyCycles < 3; dutyCycles++) { // Minimum duty execution for instant snap
        digitalWrite(PIN_ACT_SERVO, HIGH);
        delayMicroseconds(highPulseDuration);
        digitalWrite(PIN_ACT_SERVO, LOW);
        delayMicroseconds(20000 - highPulseDuration);
    }
}

void setup() {
    Serial.begin(9600);
    
    pinMode(PIN_ACT_SERVO, OUTPUT);
    pinMode(PIN_ACT_RELAY, OUTPUT);
    pinMode(PIN_ACT_BUZZER, OUTPUT);
    
    pinMode(PIN_LED_GREEN, OUTPUT);
    pinMode(PIN_LED_YELLOW, OUTPUT);
    pinMode(PIN_LED_RED, OUTPUT);
    pinMode(PIN_SENS_PIR, INPUT);
    
    positionMicroServo(0);
    digitalWrite(PIN_ACT_RELAY, LOW);
    
    lcd.begin(16, 2);
    lcd.clear();
    lcd.print("BioPulse Engine");
    lcd.setCursor(0, 1);
    lcd.print("System Ready...");
    delay(500); // Short startup flash
    lcd.clear();
    
    Serial.println(F("[SYSTEM INITIALIZED] - Optimized Demo Mode Active."));
}

// --- DEMO-DRIVEN INFERENCE MATRIX ---
void executeEdgeInferenceMatrix(float tempC, int gasRaw, int pirMotion, int luxRaw) {
    // SCENARIO 3: CRITICAL FIRE ALERT (High Gas + High Heat)
    if (tempC > (adaptiveBaselineTemp + 5.0) && gasRaw > (adaptiveBaselineGas + 80)) {
        lcd.setCursor(0, 0); lcd.print("## FIRE ALERT ##");
        lcd.setCursor(0, 1); lcd.print("Venting Perimeter");
        
        digitalWrite(PIN_LED_RED, HIGH);
        tone(PIN_ACT_BUZZER, 2200);        
        digitalWrite(PIN_ACT_RELAY, HIGH); // Snap relay over
        positionMicroServo(180);           // Swing servo wide open to 180
        return;
    }
    
    // SCENARIO 2: COOKING MODE (Motion + Temperature Rise)
    if (pirMotion == HIGH && tempC > (adaptiveBaselineTemp + 2.0)) {
        lcd.setCursor(0, 0); lcd.print("Mode: Cooking   ");
        lcd.setCursor(0, 1); lcd.print("Aux Fan Active  ");
        
        digitalWrite(PIN_LED_RED, LOW);
        noTone(PIN_ACT_BUZZER);
        digitalWrite(PIN_ACT_RELAY, LOW);
        positionMicroServo(45);            // Actuate fan vector to 45
        return;
    }

    // Default System State when awake but sorting data
    lcd.setCursor(0, 0); lcd.print("AI Awake Process");
    lcd.setCursor(0, 1); lcd.print("Analyzing Edge..");
}

void loop() {
    unsigned long currentMillis = millis();
    
    int rawTempVal = analogRead(PIN_SENS_TEMP);
    int rawGasVal  = analogRead(PIN_SENS_GAS);
    int rawLDRVal  = analogRead(PIN_SENS_LDR);
    int rawPIRVal  = digitalRead(PIN_SENS_PIR);
    float currentCelsius = (calculateVoltage(rawTempVal) - 0.5) * 100.0;

    // Fast-Interval Neuromorphic Processing Engine
    if (currentMillis - previousSamplingTime >= SAMPLING_INTERVAL) {
        previousSamplingTime = currentMillis;

        float deltaTemp = abs(rawTempVal - prevRawTemp);
        float deltaGas  = abs(rawGasVal - prevRawGas);
        float deltaLDR  = abs(rawLDRVal - prevRawLDR);
        
        membranePotentialTemp += deltaTemp;
        membranePotentialGas  += deltaGas;
        membranePotentialLDR  += deltaLDR;
        
        // High leakage prevents threshold sticking
        membranePotentialTemp = max(0.0, membranePotentialTemp - LEAK_RATE);
        membranePotentialGas  = max(0.0, membranePotentialGas - LEAK_RATE);
        membranePotentialLDR  = max(0.0, membranePotentialLDR - LEAK_RATE);
        
        prevRawTemp = rawTempVal;
        prevRawGas  = rawGasVal;
        prevRawLDR  = rawLDRVal;

        // Smooth background adaptation running passively
        adaptiveBaselineTemp = (adaptiveBaselineTemp * 0.99) + (currentCelsius * 0.01);
        adaptiveBaselineGas  = (adaptiveBaselineGas * 0.99) + (rawGasVal * 0.01);
    }
    
    // Evaluate Composite Synaptic Network Potentials
    float aggregatedSynapticNetworkActionPotential = 0.0;
    if (membranePotentialTemp > SPIKE_THRESHOLD)   aggregatedSynapticNetworkActionPotential += 10.0; 
    if (membranePotentialGas > SPIKE_THRESHOLD)    aggregatedSynapticNetworkActionPotential += 10.0; 
    if (membranePotentialLDR > SPIKE_THRESHOLD)    aggregatedSynapticNetworkActionPotential += 5.0; 
    if (rawPIRVal == HIGH)                         aggregatedSynapticNetworkActionPotential += 20.0; 

    // State Routing Controller
    if (aggregatedSynapticNetworkActionPotential >= GLOBAL_ACTIVATION) {
        isSystemAwake = true;
        previousWakeHoldTime = currentMillis; // Keep feeding our countdown timer while sliders are hot
        
        digitalWrite(PIN_LED_GREEN, LOW);
        digitalWrite(PIN_LED_YELLOW, HIGH);
        
        executeEdgeInferenceMatrix(currentCelsius, rawGasVal, rawPIRVal, rawLDRVal);
        forceLcdUpdate = true;
    } 
    // Fall back to sleep state instantly after 750ms of complete quiet
    else if (isSystemAwake && (currentMillis - previousWakeHoldTime >= WAKE_HOLD_DURATION)) {
        isSystemAwake = false;
        noTone(PIN_ACT_BUZZER);
        digitalWrite(PIN_ACT_RELAY, LOW);
        positionMicroServo(0);
        forceLcdUpdate = true;
    }

    // SCENARIO 1: FORCE SLEEP MODE
    if (!isSystemAwake) {
        digitalWrite(PIN_LED_GREEN, HIGH);
        digitalWrite(PIN_LED_YELLOW, LOW);
        digitalWrite(PIN_LED_RED, LOW);
        
        if (forceLcdUpdate) {
            lcd.setCursor(0, 0); lcd.print("BioPulse: Sleep ");
            lcd.setCursor(0, 1); lcd.print("Power State: uW ");
            forceLcdUpdate = false; 
        }
    }
}
